{{ 'cookku-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign has_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign has_sale = true
  endif
  assign current_collection = collection
  if current_collection == blank
    assign current_collection = product.collections.first
  endif

  comment
    Bullets: read from metafield "custom.bullets" (list.single_line_text_field)
    Fallback: section blocks of type "bullet"
    To set up metafields: Shopify Admin → Settings → Custom data → Products → Add definition
    Namespace: custom | Key: bullets | Type: List of single-line text
  endcomment
  assign bullets_meta = product.metafields.custom.bullets.value
-%}

<!-- Breadcrumb -->
<nav class="ck-breadcrumb" aria-label="Breadcrumb">
  <a href="/">Home</a>
  <span class="ck-breadcrumb__sep">›</span>
  {%- if current_collection -%}
    <a href="{{ current_collection.url }}">{{ current_collection.title }}</a>
    <span class="ck-breadcrumb__sep">›</span>
  {%- endif -%}
  <span>{{ product.title }}</span>
</nav>

<!-- Product Hero -->
<div class="ck-product-hero">
  <div class="ck-product-hero__inner">

    <!-- LEFT: Image Gallery -->
    <div class="ck-product-gallery">
      {%- if product.tags contains 'new' -%}
        <span class="ck-product-gallery__badge">NEW</span>
      {%- elsif product.tags contains 'best-seller' -%}
        <span class="ck-product-gallery__badge">BEST SELLER</span>
      {%- endif -%}

      <div class="ck-product-gallery__main">
        {%- if product.featured_image -%}
          <img
            id="ck-main-product-img"
            src="{{ product.featured_image | image_url: width: 700 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="700"
            loading="eager"
          >
        {%- else -%}
          <div class="ck-product-gallery__placeholder">
            [ Product image — {{ product.title }} ]
          </div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="ck-product-gallery__thumbs">
          {%- for image in product.images limit: 5 -%}
            <div
              class="ck-product-gallery__thumb {% if forloop.first %}ck-thumb-active{% endif %}"
              data-full="{{ image | image_url: width: 700 }}"
              role="button"
              tabindex="0"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="lazy"
              >
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- RIGHT: Product Info + Form -->
    <div class="ck-product-info">

      {%- if product.vendor != blank -%}
        <p class="ck-product-eyebrow">{{ product.vendor | upcase }}</p>
      {%- elsif section.settings.eyebrow != blank -%}
        <p class="ck-product-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="ck-product-title">{{ product.title }}</h1>

      <div class="ck-product-stars">
        <span class="ck-product-stars__icons">★★★★★</span>
        <span class="ck-product-stars__label">
          {%- if product.metafields.reviews.rating_count -%}
            {{ product.metafields.reviews.rating_count }} reviews
          {%- else -%}
            New product. Be the first to review.
          {%- endif -%}
        </span>
      </div>

      <div class="ck-product-price-row">
        <span class="ck-product-price-sale" id="ck-price-sale">
          {{ current_variant.price | money }}
        </span>
        {%- if has_sale -%}
          <s class="ck-product-price-compare" id="ck-price-compare">
            {{ current_variant.compare_at_price | money }}
          </s>
          <span class="ck-product-sale-badge">SALE</span>
        {%- endif -%}
      </div>

      <p class="ck-product-shipping-note">Free US Shipping. Taxes calculated at checkout.</p>
      <hr class="ck-product-divider">

      <!-- Feature Bullets: metafield → blocks fallback -->
      {%- if bullets_meta and bullets_meta.size > 0 -%}
        <ul class="ck-product-bullets">
          {%- for bullet in bullets_meta -%}
            <li>{{ bullet }}</li>
          {%- endfor -%}
        </ul>
      {%- elsif section.blocks.size > 0 -%}
        <ul class="ck-product-bullets">
          {%- for block in section.blocks -%}
            {%- if block.type == 'bullet' -%}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- form 'product', product, id: 'CookkuProductForm', novalidate: 'novalidate' -%}

        <input type="hidden" name="id" id="ck-variant-id" value="{{ current_variant.id }}">

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="ck-variant-group">
              <span class="ck-variant-label">{{ option.name }}</span>
              <div class="ck-variant-options">
                {%- for value in option.values -%}
                  <button
                    type="button"
                    class="ck-variant-btn{% if option.selected_value == value %} ck-variant-active{% endif %}"
                    data-option-position="{{ option.position }}"
                    data-option-value="{{ value | escape }}"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <div class="ck-form-row">
          <div class="ck-qty-selector">
            <button type="button" class="ck-qty-btn" id="ck-qty-minus" aria-label="Decrease quantity">−</button>
            <input
              type="number"
              name="quantity"
              id="ck-quantity"
              value="1"
              min="1"
              class="ck-qty-input"
              aria-label="Quantity"
            >
            <button type="button" class="ck-qty-btn" id="ck-qty-plus" aria-label="Increase quantity">+</button>
          </div>
          <button
            type="submit"
            name="add"
            class="ck-btn-add-to-cart"
            id="ck-add-to-cart"
            {%- unless current_variant.available -%}disabled{%- endunless -%}
          >
            {%- if current_variant.available -%}
              ADD TO CART — <span id="ck-btn-price">{{ current_variant.price | money }}</span>
            {%- else -%}
              SOLD OUT
            {%- endif -%}
          </button>
        </div>

        {%- if section.settings.show_buy_now -%}
          {{ form | payment_button }}
        {%- endif -%}

      {%- endform -%}

      <!-- Mini Trust Strip -->
      <div class="ck-product-trust-mini">
        <div class="ck-product-trust-mini__item">
          <span class="ck-product-trust-mini__icon">🚚</span>
          <span class="ck-product-trust-mini__label">Free Shipping</span>
          <span class="ck-product-trust-mini__sub">On every order</span>
        </div>
        <div class="ck-product-trust-mini__item">
          <span class="ck-product-trust-mini__icon">♻️</span>
          <span class="ck-product-trust-mini__label">30-Day Returns</span>
          <span class="ck-product-trust-mini__sub">Hassle-free</span>
        </div>
        <div class="ck-product-trust-mini__item">
          <span class="ck-product-trust-mini__icon">🔒</span>
          <span class="ck-product-trust-mini__label">Secure</span>
          <span class="ck-product-trust-mini__sub">SSL checkout</span>
        </div>
        <div class="ck-product-trust-mini__item">
          <span class="ck-product-trust-mini__icon">⭐</span>
          <span class="ck-product-trust-mini__label">Hand-Picked</span>
          <span class="ck-product-trust-mini__sub">Quality tested</span>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  (function () {
    /* Thumbnail switcher */
    document.querySelectorAll('.ck-product-gallery__thumb').forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        document.querySelectorAll('.ck-product-gallery__thumb').forEach(function (t) { t.classList.remove('ck-thumb-active'); });
        this.classList.add('ck-thumb-active');
        var mainImg = document.getElementById('ck-main-product-img');
        if (mainImg) mainImg.src = this.dataset.full;
      });
      thumb.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this.click(); }
      });
    });

    /* Quantity selector */
    var qtyInput = document.getElementById('ck-quantity');
    var minusBtn = document.getElementById('ck-qty-minus');
    var plusBtn  = document.getElementById('ck-qty-plus');
    if (minusBtn) minusBtn.addEventListener('click', function () {
      var v = parseInt(qtyInput.value) || 1;
      if (v > 1) qtyInput.value = v - 1;
    });
    if (plusBtn) plusBtn.addEventListener('click', function () {
      qtyInput.value = (parseInt(qtyInput.value) || 1) + 1;
    });

    /* Variant selection */
    var productVariants = {{ product.variants | json }};
    document.querySelectorAll('.ck-variant-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var pos = this.dataset.optionPosition;
        document.querySelectorAll('.ck-variant-btn[data-option-position="' + pos + '"]').forEach(function (b) { b.classList.remove('ck-variant-active'); });
        this.classList.add('ck-variant-active');

        var selected = {};
        document.querySelectorAll('.ck-variant-btn.ck-variant-active').forEach(function (b) {
          selected[b.dataset.optionPosition] = b.dataset.optionValue;
        });

        var match = productVariants.find(function (v) {
          return Object.keys(selected).every(function (p) { return v['option' + p] === selected[p]; });
        });

        if (match) {
          document.getElementById('ck-variant-id').value = match.id;
          var priceEl   = document.getElementById('ck-price-sale');
          var compareEl = document.getElementById('ck-price-compare');
          var btnPrice  = document.getElementById('ck-btn-price');
          var addBtn    = document.getElementById('ck-add-to-cart');
          var fmt = function (c) { return '$' + (c / 100).toFixed(2); };
          if (priceEl)   priceEl.textContent   = fmt(match.price);
          if (btnPrice)  btnPrice.textContent   = fmt(match.price);
          if (compareEl) compareEl.textContent  = match.compare_at_price > match.price ? fmt(match.compare_at_price) : '';
          if (addBtn) {
            addBtn.disabled = !match.available;
            if (!match.available) addBtn.textContent = 'SOLD OUT';
          }
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Cookku Main Product",
  "settings": [
    {
      "type": "paragraph",
      "content": "Feature bullets are read from the product metafield: namespace = custom, key = bullets (List of single-line text). If not set, falls back to the blocks below."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow override (used if product has no vendor)",
      "default": "COOKKU KITCHEN"
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Show Buy it Now button",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Feature bullet (fallback)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Bullet text",
          "default": "Feature highlight"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Cookku Main Product" }
  ]
}
{% endschema %}
