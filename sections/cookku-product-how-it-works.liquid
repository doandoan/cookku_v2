{{ 'cookku-product.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Reads from metafield: custom.how_it_works (JSON type)
  Expected format: [{"number":"1","title":"STEP TITLE","desc":"Step description"}, ...]
  Fallback: section blocks
{%- endcomment -%}

{%- assign steps_meta = product.metafields.custom.how_it_works.value -%}

<section class="ck-how-it-works">
  <div class="ck-section-inner">
    <div class="ck-how-it-works__header">
      {% if section.settings.eyebrow != blank %}
        <p class="ck-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="ck-section-title">
        {{ section.settings.title_before }} <em>{{ section.settings.title_em }}</em>
      </h2>
    </div>

    <div class="ck-how-it-works__grid">
      {%- if steps_meta and steps_meta.size > 0 -%}
        {%- for step in steps_meta -%}
          <div class="ck-step-card">
            <div class="ck-step-card__number">{{ step.number }}</div>
            <h3 class="ck-step-card__title">{{ step.title }}</h3>
            <p class="ck-step-card__desc">{{ step.desc }}</p>
          </div>
        {%- endfor -%}
      {%- elsif section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="ck-step-card" {{ block.shopify_attributes }}>
            <div class="ck-step-card__number">{{ block.settings.number }}</div>
            <h3 class="ck-step-card__title">{{ block.settings.title }}</h3>
            <p class="ck-step-card__desc">{{ block.settings.description }}</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cookku How It Works",
  "settings": [
    {
      "type": "paragraph",
      "content": "Content is read from product metafield custom.how_it_works (JSON array). Format: [{\"number\":\"1\",\"title\":\"STEP\",\"desc\":\"...\"}]"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "IN THREE SIMPLE STEPS" },
    { "type": "text", "id": "title_before", "label": "Title — before italic", "default": "How it" },
    { "type": "text", "id": "title_em", "label": "Title — italic word", "default": "works" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step (fallback)",
      "settings": [
        { "type": "text", "id": "number", "label": "Step number", "default": "1" },
        { "type": "text", "id": "title", "label": "Title", "default": "STEP TITLE" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Step description." }
      ]
    }
  ],
  "presets": [
    { "name": "Cookku How It Works" }
  ]
}
{% endschema %}
