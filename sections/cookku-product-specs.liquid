{{ 'cookku-product.css' | asset_url | stylesheet_tag }}

<section class="ck-specs">
  <div class="ck-section-inner">
    <div class="ck-specs__header">
      {% if section.settings.eyebrow != blank %}
        <p class="ck-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="ck-section-title">{{ section.settings.title }}</h2>
    </div>
    <table class="ck-specs__table">
      <tbody>
        {% for block in section.blocks %}
          <tr {{ block.shopify_attributes }}>
            <td class="ck-specs__label">{{ block.settings.label }}</td>
            <td class="ck-specs__value">{{ block.settings.value }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

{% schema %}
{
  "name": "Cookku Product Specs",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "PRODUCT DETAILS" },
    { "type": "text", "id": "title", "label": "Title", "default": "Specifications" }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Specification row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Material" },
        { "type": "text", "id": "value", "label": "Value", "default": "Aluminum Alloy" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cookku Product Specs",
      "blocks": [
        { "type": "spec", "settings": { "label": "Material", "value": "Heavy Duty Aluminum Alloy" } },
        { "type": "spec", "settings": { "label": "Color", "value": "Silver" } },
        { "type": "spec", "settings": { "label": "Dimensions", "value": "21.5 × 12.5 × 12.5 cm" } },
        { "type": "spec", "settings": { "label": "Weight", "value": "Approx. 320g" } },
        { "type": "spec", "settings": { "label": "Suitable for", "value": "Lemon, Lime, Orange, Pomegranate" } },
        { "type": "spec", "settings": { "label": "Cleaning", "value": "Hand-Wash, Rinse-Clean" } },
        { "type": "spec", "settings": { "label": "Power source", "value": "Manual (No Electricity Needed)" } },
        { "type": "spec", "settings": { "label": "Package includes", "value": "1× FreshTaste™ Metal Citrus Press" } }
      ]
    }
  ]
}
{% endschema %}
