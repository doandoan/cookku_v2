{{ 'cookku-cart.css' | asset_url | stylesheet_tag }}

{%- assign loved_collection = collections[section.settings.collection] -%}

{% if loved_collection and loved_collection.products_count > 0 %}
<section class="ck-cart-loved">
  <div class="ck-cart-loved__header">
    {% if section.settings.eyebrow != blank %}
      <p class="ck-cart-section-eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2 class="ck-cart-section-title">
      {{ section.settings.title_before }} <em>{{ section.settings.title_em }}</em>
    </h2>
  </div>

  <div class="ck-cart-loved__grid">
    {% for product in loved_collection.products limit: 4 %}
      {%- liquid
        assign badge_text = ''
        assign badge_class = ''
        if product.tags contains 'best-seller'
          assign badge_text = 'BEST SELLER'
          assign badge_class = 'cookku-badge--green'
        elsif product.compare_at_price > product.price
          assign disc = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
          assign badge_text = '-' | append: disc | append: '%'
          assign badge_class = 'cookku-badge--red'
        elsif product.tags contains 'new'
          assign badge_text = 'NEW'
          assign badge_class = 'cookku-badge--dark'
        endif
      -%}
      <div class="cookku-product-card">
        <div class="cookku-product-card__image-wrap">
          {% if badge_text != '' %}
            <span class="cookku-badge {{ badge_class }}">{{ badge_text }}</span>
          {% endif %}
          {% if product.featured_image %}
            {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: product.title }}
          {% else %}
            <div class="cookku-product-card__img-placeholder">{{ product.title }}</div>
          {% endif %}
        </div>
        <div class="cookku-product-card__info">
          <a href="{{ product.url }}" class="cookku-product-card__title">{{ product.title }}</a>
          <div class="cookku-product-card__footer">
            <div class="cookku-product-card__price">
              <span class="cookku-price-sale">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <s class="cookku-price-compare">{{ product.compare_at_price | money }}</s>
              {% endif %}
            </div>
            <button
              type="button"
              class="ck-rl-cart-btn ck-rl-add"
              data-variant-id="{{ product.selected_or_first_available_variant.id }}"
              aria-label="Add {{ product.title | escape }} to cart"
              {%- unless product.available -%}disabled{%- endunless -%}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>
{% endif %}

<script>
  (function () {
    document.querySelectorAll('.ck-rl-add').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var variantId = parseInt(this.dataset.variantId, 10);
        if (!variantId) return;
        var self = this;
        self.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
        })
          .then(function (r) { return r.json(); })
          .then(function () { window.location.reload(); })
          .catch(function () { self.disabled = false; });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Cookku Cart — Recently Loved",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "RECENTLY VIEWED" },
    { "type": "text", "id": "title_before", "label": "Title — before italic", "default": "You might also" },
    { "type": "text", "id": "title_em", "label": "Title — italic word", "default": "love" },
    {
      "type": "collection",
      "id": "collection",
      "label": "Products collection"
    }
  ],
  "presets": [
    { "name": "Cookku Cart — Recently Loved" }
  ]
}
{% endschema %}
