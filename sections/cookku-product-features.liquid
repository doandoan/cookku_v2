{{ 'cookku-product.css' | asset_url | stylesheet_tag }}

<section class="ck-features">
  <div class="ck-section-inner">
    <div class="ck-features__header">
      {% if section.settings.eyebrow != blank %}
        <p class="ck-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="ck-section-title">
        {{ section.settings.title_before }} <em>{{ section.settings.title_em }}</em>
      </h2>
    </div>
    <div class="ck-features__grid">
      {% for block in section.blocks %}
        <div class="ck-feature-card" {{ block.shopify_attributes }}>
          <span class="ck-feature-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          <h3 class="ck-feature-card__title">{{ block.settings.title }}</h3>
          <p class="ck-feature-card__desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cookku Product Features",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "WHY YOU'LL LOVE IT"
    },
    {
      "type": "text",
      "id": "title_before",
      "label": "Title — before italic",
      "default": "Six reasons it earns"
    },
    {
      "type": "text",
      "id": "title_em",
      "label": "Title — italic word",
      "default": "counter space"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "⭐" },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Feature description." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cookku Product Features",
      "blocks": [
        { "type": "feature", "settings": { "icon": "⏱️", "title": "Pure juice in 3 seconds", "description": "Squeeze every drop. Perfect for drinks, dressings, and marinades." } },
        { "type": "feature", "settings": { "icon": "💪", "title": "Heavy-duty aluminum", "description": "Solid single-piece alloy body with long-leverage handle. Maximum juice, minimum effort." } },
        { "type": "feature", "settings": { "icon": "🔩", "title": "Built-in seed filter", "description": "Integrated mesh catches seeds and ensures pulp-free juice. No straining required." } },
        { "type": "feature", "settings": { "icon": "🍸", "title": "Bartender-grade", "description": "Cocktails, mocktails, lemonades, marmalades. Restaurant flavor at home." } },
        { "type": "feature", "settings": { "icon": "💧", "title": "Rinse-clean in seconds", "description": "No coils, batteries, or sticky parts. A quick rinse is all it takes." } },
        { "type": "feature", "settings": { "icon": "🔇", "title": "No electricity, no noise", "description": "Squeeze anywhere — kitchen, dorm, RV, Compact and completely silent." } }
      ]
    }
  ]
}
{% endschema %}
