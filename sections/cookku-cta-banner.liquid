{{ 'cookku-homepage.css' | asset_url | stylesheet_tag }}

<section class="cookku-cta-banner">
  <div class="cookku-cta-banner__inner">

    <div class="cookku-cta-banner__content">
      <h2 class="cookku-cta-banner__heading">
        {{ section.settings.heading_line1 }}<br>
        {{ section.settings.heading_line2 }}
      </h2>
      {% if section.settings.subtext != blank %}
        <p class="cookku-cta-banner__subtext">{{ section.settings.subtext }}</p>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_url }}" class="cookku-btn cookku-btn--primary">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="cookku-cta-banner__image">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 700
          | image_tag: loading: 'lazy', alt: section.settings.image.alt
        }}
      {% else %}
        <div class="cookku-cta-banner__image-placeholder">
          [ Lifestyle image — happy kitchen scene ]
        </div>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Cookku CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading — line 1",
      "default": "Upgrade Your Home."
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading — line 2",
      "default": "Simplify Your Life."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Shop our best picks and enjoy everyday convenience."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Best Picks →"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Cookku CTA Banner"
    }
  ]
}
{% endschema %}
