{{ 'cookku-product.css' | asset_url | stylesheet_tag }}

<section class="ck-product-cta">
  {% if section.settings.eyebrow != blank %}
    <p class="ck-product-cta__eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}
  <h2 class="ck-product-cta__heading">
    {{ section.settings.heading }}<br>
    <em>{{ section.settings.heading_em }}</em>
  </h2>
  {% if section.settings.subtext != blank %}
    <p class="ck-product-cta__subtext">{{ section.settings.subtext }}</p>
  {% endif %}

  {%- assign cta_product = all_products[section.settings.product] -%}
  {%- if cta_product != blank -%}
    {%- form 'product', cta_product, id: 'CookkuCtaForm' -%}
      <input type="hidden" name="id" value="{{ cta_product.selected_or_first_available_variant.id }}">
      <button type="submit" name="add" class="ck-product-cta__btn">
        {{ section.settings.button_label }}
      </button>
    {%- endform -%}
  {%- else -%}
    <a href="{{ section.settings.button_url | default: product.url }}" class="ck-product-cta__btn">
      {{ section.settings.button_label }}
    </a>
  {%- endif -%}

  {% if section.settings.trust_text != blank %}
    <p class="ck-product-cta__trust">{{ section.settings.trust_text }}</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Cookku Product CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "FRESHTASTE™ KITCHEN" },
    { "type": "text", "id": "heading", "label": "Heading line 1", "default": "Fresh Juice, Zero Mess." },
    { "type": "text", "id": "heading_em", "label": "Heading line 2 (italic green)", "default": "Pure Flavor." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Bring restaurant-quality citrus juice to every meal — from morning brunch water to weekend cocktails." },
    { "type": "product", "id": "product", "label": "Product (for add-to-cart)" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "ADD TO CART — $19.99" },
    { "type": "url", "id": "button_url", "label": "Button URL (fallback if no product)" },
    { "type": "text", "id": "trust_text", "label": "Trust line below button", "default": "🚚 Free US Shipping  |  ✓ 30-Day Guarantee  |  🔒 Secure Checkout" }
  ],
  "presets": [
    {
      "name": "Cookku Product CTA"
    }
  ]
}
{% endschema %}
