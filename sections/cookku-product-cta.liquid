{{ 'cookku-product.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Uses the current product on the page — no hardcoded product needed.
  Button price is always pulled from product.price dynamically.
{%- endcomment -%}

<section class="ck-product-cta">
  {% if section.settings.eyebrow != blank %}
    <p class="ck-product-cta__eyebrow">{{ section.settings.eyebrow }}</p>
  {% endif %}

  <h2 class="ck-product-cta__heading">
    {{ section.settings.heading }}<br>
    <em>{{ section.settings.heading_em }}</em>
  </h2>

  {% if section.settings.subtext != blank %}
    <p class="ck-product-cta__subtext">{{ section.settings.subtext }}</p>
  {% endif %}

  {%- assign cta_variant = product.selected_or_first_available_variant -%}

  {%- form 'product', product, id: 'CookkuCtaForm' -%}
    <input type="hidden" name="id" value="{{ cta_variant.id }}">
    <button
      type="submit"
      name="add"
      class="ck-product-cta__btn"
      {%- unless cta_variant.available -%}disabled{%- endunless -%}
    >
      {%- if cta_variant.available -%}
        {{ section.settings.button_prefix }} — {{ cta_variant.price | money }}
      {%- else -%}
        SOLD OUT
      {%- endif -%}
    </button>
  {%- endform -%}

  {% if section.settings.trust_text != blank %}
    <p class="ck-product-cta__trust">{{ section.settings.trust_text }}</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Cookku Product CTA",
  "settings": [
    {
      "type": "paragraph",
      "content": "This section automatically uses the current product. Price is pulled dynamically from the product."
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "COOKKU KITCHEN" },
    { "type": "text", "id": "heading", "label": "Heading line 1", "default": "Fresh Juice, Zero Mess." },
    { "type": "text", "id": "heading_em", "label": "Heading line 2 (italic green)", "default": "Pure Flavor." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Bring restaurant-quality citrus juice to every meal — from morning brunch water to weekend cocktails." },
    { "type": "text", "id": "button_prefix", "label": "Button text prefix", "default": "ADD TO CART" },
    { "type": "text", "id": "trust_text", "label": "Trust line below button", "default": "🚚 Free US Shipping  |  ✓ 30-Day Guarantee  |  🔒 Secure Checkout" }
  ],
  "presets": [
    { "name": "Cookku Product CTA" }
  ]
}
{% endschema %}
